<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mangiare Pizzería · Napoletana en La Florida</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,500;1,9..144,700&family=Work+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --charcoal:#20140f;
    --charcoal-2:#2b1c14;
    --cream:#f4e8cc;
    --cream-dim:#e3d4ae;
    --tomato:#c1391f;
    --tomato-dark:#8f2916;
    --basil:#5a7042;
    --crust:#d79a4c;
    --ember:#ea6a2c;
    --line: rgba(244,232,204,0.14);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--charcoal);
    color:var(--cream);
    font-family:'Work Sans', sans-serif;
    line-height:1.5;
    overflow-x:hidden;
  }
  @media (prefers-reduced-motion: reduce){
    *{animation:none !important; transition:none !important;}
  }
  a{color:inherit;}
  .display{font-family:'Fraunces', serif;}
  .mono{font-family:'JetBrains Mono', monospace;}
  .wrap{max-width:1080px; margin:0 auto; padding:0 28px;}

  /* ---------- NAV ---------- */
  nav{
    position:fixed; top:0; left:0; right:0; z-index:50;
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 28px;
    background:linear-gradient(to bottom, rgba(32,20,15,0.95), rgba(32,20,15,0));
  }
  .brand{
    display:flex; align-items:center; gap:10px;
    font-family:'Fraunces', serif; font-weight:700; font-style:italic;
    font-size:1.25rem; letter-spacing:0.01em;
  }
  .brand-mark{
    width:14px; height:14px; border-radius:50%;
    background:radial-gradient(circle at 35% 35%, var(--crust), var(--tomato) 70%);
    box-shadow:0 0 12px rgba(234,106,44,0.7);
  }
  .nav-cta{
    font-family:'JetBrains Mono', monospace; font-size:0.78rem; letter-spacing:0.03em;
    text-transform:uppercase; text-decoration:none;
    border:1px solid var(--cream-dim); padding:9px 16px; border-radius:2px;
    transition:background .2s, color .2s;
  }
  .nav-cta:hover{ background:var(--cream); color:var(--charcoal); }

  /* ---------- HERO ---------- */
  .hero{
    position:relative; min-height:100svh;
    display:flex; flex-direction:column; justify-content:flex-end;
    padding:140px 0 90px;
    background:
      radial-gradient(ellipse 900px 500px at 78% 8%, rgba(234,106,44,0.28), transparent 60%),
      radial-gradient(ellipse 700px 500px at 15% 85%, rgba(90,112,66,0.18), transparent 55%),
      var(--charcoal);
  }
  .hero::before{
    content:""; position:absolute; inset:0; pointer-events:none;
    background-image: radial-gradient(rgba(244,232,204,0.05) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse 100% 60% at 50% 30%, black 30%, transparent 90%);
  }
  .status-badge{
    display:inline-flex; align-items:center; gap:8px;
    font-family:'JetBrains Mono', monospace; font-size:0.78rem; letter-spacing:0.03em;
    text-transform:uppercase; color:var(--cream-dim);
    border:1px solid var(--line); border-radius:20px; padding:7px 14px;
    width:fit-content; margin-bottom:26px;
  }
  .dot{ width:7px; height:7px; border-radius:50%; background:#7fbf6a; box-shadow:0 0 8px #7fbf6a; animation:pulse 2s infinite; }
  @keyframes pulse{ 0%,100%{opacity:1;} 50%{opacity:0.35;} }

  .hero h1{
    font-size:clamp(2.6rem, 7vw, 5.4rem);
    font-weight:600; line-height:0.98; letter-spacing:-0.01em;
    max-width:820px; margin-bottom:22px;
  }
  .hero h1 em{ font-style:italic; font-weight:500; color:var(--crust); }
  .hero p.sub{
    max-width:480px; font-size:1.08rem; color:var(--cream-dim);
    margin-bottom:36px;
  }
  .hero-actions{ display:flex; flex-wrap:wrap; gap:14px; margin-bottom:56px; }
  .btn{
    font-family:'JetBrains Mono', monospace; font-size:0.82rem; letter-spacing:0.02em;
    text-transform:uppercase; text-decoration:none; padding:14px 24px; border-radius:2px;
    display:inline-flex; align-items:center; gap:8px; transition:transform .18s, box-shadow .18s;
  }
  .btn-primary{ background:var(--tomato); color:var(--cream); box-shadow:0 8px 24px -8px rgba(193,57,31,0.7); }
  .btn-primary:hover{ transform:translateY(-2px); box-shadow:0 12px 28px -8px rgba(193,57,31,0.85); }
  .btn-ghost{ border:1px solid var(--line); color:var(--cream); }
  .btn-ghost:hover{ border-color:var(--cream); }

  .hero-stats{
    display:flex; gap:36px; flex-wrap:wrap;
    border-top:1px solid var(--line); padding-top:28px; max-width:700px;
  }
  .stat b{ display:block; font-family:'Fraunces', serif; font-size:2rem; font-weight:600; color:var(--crust); }
  .stat span{ font-size:0.8rem; color:var(--cream-dim); text-transform:uppercase; letter-spacing:0.03em; font-family:'JetBrains Mono', monospace; }

  /* ---------- CORNICIONE DIVIDER (signature) ---------- */
  .cornicione{ width:100%; height:34px; display:block; }
  .cornicione path{ fill:var(--charcoal-2); }
  .cornicione.flip path{ fill:var(--charcoal); }

  /* ---------- SECTION SHARED ---------- */
  section{ position:relative; }
  .section-pad{ padding:80px 0; }
  .eyebrow{
    font-family:'JetBrains Mono', monospace; font-size:0.78rem; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--crust); margin-bottom:14px;
  }
  h2.display{
    font-size:clamp(1.9rem, 4vw, 2.8rem); font-weight:600; margin-bottom:20px; max-width:640px;
  }

  /* ---------- ABOUT ---------- */
  .about{ background:var(--charcoal-2); }
  .about-grid{
    display:grid; grid-template-columns:1.1fr 0.9fr; gap:64px; align-items:start;
  }
  .about p{ color:var(--cream-dim); max-width:480px; margin-bottom:18px; }
  .oven-card{
    border:1px solid var(--line); border-radius:4px; padding:28px;
    background:linear-gradient(160deg, rgba(234,106,44,0.08), transparent);
  }
  .oven-card .label{ font-family:'JetBrains Mono', monospace; font-size:0.75rem; text-transform:uppercase; color:var(--cream-dim); letter-spacing:0.04em; margin-bottom:6px; }
  .oven-card .big{ font-family:'Fraunces', serif; font-style:italic; font-size:1.6rem; color:var(--cream); margin-bottom:22px; }
  .tag-row{ display:flex; flex-wrap:wrap; gap:8px; }
  .tag{
    font-family:'JetBrains Mono', monospace; font-size:0.72rem; text-transform:uppercase;
    border:1px solid var(--line); border-radius:20px; padding:6px 12px; color:var(--cream-dim);
  }

  /* ---------- MENU ---------- */
  .menu{ background:var(--charcoal); }
  .menu-head{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:16px; margin-bottom:12px; }
  .menu-sub{ font-family:'Fraunces', serif; font-style:italic; color:var(--cream-dim); font-size:1.05rem; margin-bottom:48px; }
  .menu-cols{ display:grid; grid-template-columns:1fr 1fr; gap:56px; }
  .menu-cat{ margin-bottom:44px; }
  .menu-cat:last-child{ margin-bottom:0; }
  .menu-cat-title{
    font-family:'JetBrains Mono', monospace; font-size:0.78rem; letter-spacing:0.08em;
    text-transform:uppercase; color:var(--crust);
    display:flex; align-items:center; gap:10px; margin-bottom:22px;
  }
  .menu-cat-title::after{ content:""; flex:1; height:1px; background:var(--line); }
  .menu-item{ margin-bottom:22px; }
  .menu-item:last-child{ margin-bottom:0; }
  .menu-item-row{ display:flex; align-items:baseline; gap:8px; }
  .menu-item-row .name{ font-family:'Fraunces', serif; font-weight:600; font-size:1.06rem; white-space:nowrap; }
  .menu-item-row .leader{ flex:1; border-bottom:2px dotted var(--line); transform:translateY(-4px); }
  .menu-item-row .price{ font-family:'JetBrains Mono', monospace; font-size:0.98rem; color:var(--crust); white-space:nowrap; }
  .menu-item .desc{ font-size:0.85rem; color:var(--cream-dim); margin-top:5px; max-width:440px; line-height:1.5; }

  /* ---------- REVIEWS (order-ticket style) ---------- */
  .reviews{ background:var(--charcoal); }
  .rev-head{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:20px; margin-bottom:44px; }
  .rating-block{ display:flex; align-items:center; gap:16px; }
  .rating-num{ font-family:'Fraunces', serif; font-size:3.2rem; font-weight:600; color:var(--crust); line-height:1; }
  .stars{ color:var(--crust); letter-spacing:2px; font-size:1.1rem; }
  .rating-sub{ font-family:'JetBrains Mono', monospace; font-size:0.78rem; color:var(--cream-dim); text-transform:uppercase; }

  .ticket-row{ display:grid; grid-template-columns:repeat(3,1fr); gap:22px; }
  .ticket{
    background:var(--cream); color:var(--charcoal);
    border-radius:2px; padding:26px 24px 22px;
    position:relative;
    box-shadow:0 18px 40px -20px rgba(0,0,0,0.6);
  }
  .ticket::before, .ticket::after{
    content:""; position:absolute; left:0; right:0; height:10px;
    background-image: radial-gradient(circle, var(--charcoal) 5px, transparent 5.5px);
    background-size: 16px 16px; background-position: -4px center;
  }
  .ticket::before{ top:-5px; }
  .ticket::after{ bottom:-5px; }
  .ticket .who{ font-family:'JetBrains Mono', monospace; font-size:0.78rem; font-weight:600; text-transform:uppercase; margin-bottom:2px; }
  .ticket .meta{ font-family:'JetBrains Mono', monospace; font-size:0.68rem; color:#6b5c4a; margin-bottom:14px; text-transform:uppercase; }
  .ticket .stars-mini{ color:var(--tomato-dark); font-size:0.85rem; margin-bottom:12px; letter-spacing:1px; }
  .ticket p{ font-size:0.92rem; line-height:1.55; }

  /* ---------- INFO / VISIT ---------- */
  .visit{ background:var(--charcoal-2); }
  .visit-grid{ display:grid; grid-template-columns:1fr 1fr; gap:0; border:1px solid var(--line); border-radius:4px; overflow:hidden; }
  .visit-col{ padding:40px; }
  .visit-col + .visit-col{ border-left:1px solid var(--line); }
  .info-row{ display:flex; justify-content:space-between; gap:20px; padding:14px 0; border-bottom:1px solid var(--line); }
  .info-row:last-child{ border-bottom:none; }
  .info-row .k{ font-family:'JetBrains Mono', monospace; font-size:0.75rem; text-transform:uppercase; color:var(--cream-dim); letter-spacing:0.03em; }
  .info-row .v{ font-family:'JetBrains Mono', monospace; font-size:0.88rem; text-align:right; }
  .visit-col h3{ font-family:'Fraunces', serif; font-style:italic; font-size:1.4rem; margin-bottom:18px; color:var(--crust); }
  .hours-table div{ display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--line); font-family:'JetBrains Mono', monospace; font-size:0.85rem; }
  .hours-table div:last-child{ border-bottom:none; }
  .hours-table span.today{ color:var(--crust); }

  /* ---------- FOOTER ---------- */
  footer{ background:var(--charcoal); padding:56px 0 34px; border-top:1px solid var(--line); }
  .foot-grid{ display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px; }
  .foot-note{ font-family:'JetBrains Mono', monospace; font-size:0.75rem; color:var(--cream-dim); }

  @media (max-width:760px){
    .about-grid{ grid-template-columns:1fr; gap:40px; }
    .menu-cols{ grid-template-columns:1fr; gap:8px; }
    .ticket-row{ grid-template-columns:1fr; }
    .visit-grid{ grid-template-columns:1fr; }
    .visit-col + .visit-col{ border-left:none; border-top:1px solid var(--line); }
    .hero{ padding-top:120px; }
  }

  /* focus visibility */
  a:focus-visible, button:focus-visible{ outline:2px solid var(--crust); outline-offset:3px; }
</style>
</head>
<body>

<nav>
  <div class="brand"><span class="brand-mark"></span>Mangiare</div>
