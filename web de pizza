        <span class="tag">Napolitana</span>
        <span class="tag">Sabor</span>
        <span class="tag">Rapidez</span>
        <span class="tag">A la piedra</span>
      </div>
    </div>
  </div>
</section>

<svg class="cornicione flip" viewBox="0 0 1200 34" preserveAspectRatio="none" aria-hidden="true">
